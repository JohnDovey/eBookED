<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.GenerationResultWindow"
        Title="Export"
        Width="420" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20" Spacing="12">
    <TextBlock x:Name="HeadingText" FontSize="16" FontWeight="Bold" />
    <TextBlock x:Name="DetailText" TextWrapping="Wrap" Opacity="0.8" />
    <TextBlock x:Name="CountsText" TextWrapping="Wrap" IsVisible="False" />

    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button x:Name="OpenFolderButton" Content="Open Folder" Click="OnOpenFolderClick" IsVisible="False" />
      <Button x:Name="OpenFileButton" Content="Open File" Classes="accent" Click="OnOpenFileClick" IsVisible="False" />
      <Button Content="Close" Click="OnCloseClick" />
    </StackPanel>
  </StackPanel>

</Window>
