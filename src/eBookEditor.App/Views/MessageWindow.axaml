<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.MessageWindow"
        Width="380" MinWidth="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="20" RowDefinitions="Auto,Auto">
    <TextBlock Grid.Row="0" x:Name="MessageText" TextWrapping="Wrap" />
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="OK" Classes="accent" Click="OnOkClick" />
    </StackPanel>
  </Grid>

</Window>
