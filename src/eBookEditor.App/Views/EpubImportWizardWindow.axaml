<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:eBookEditor.App.ViewModels"
        mc:Ignorable="d"
        x:Class="eBookEditor.App.Views.EpubImportWizardWindow"
        x:DataType="vm:EpubImportWizardViewModel"
        Title="Create Project from ePub"
        Width="480" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Create Project from ePub" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
    <TextBlock Text="{Binding SourceDescription}" Opacity="0.7" TextWrapping="Wrap" />

    <TextBox Watermark="Book title" Text="{Binding ProjectName}" />

    <Grid ColumnDefinitions="*,Auto">
      <TextBox Grid.Column="0" Watermark="Save location" Text="{Binding Location}" IsReadOnly="True" Margin="0,0,6,0" />
      <Button Grid.Column="1" Content="Browse…" Click="OnBrowseClick" />
    </Grid>

    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Create" Classes="accent" Click="OnCreateClick" />
    </StackPanel>
  </StackPanel>

</Window>
