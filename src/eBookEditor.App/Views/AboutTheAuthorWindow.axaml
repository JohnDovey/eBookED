<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:eBookEditor.App.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="560" d:DesignHeight="520"
        x:Class="eBookEditor.App.Views.AboutTheAuthorWindow"
        x:DataType="vm:MetadataViewModel"
        Title="About the Author"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" Padding="16">
      <StackPanel Spacing="10">

        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Watermark="Author photo path (relative to project)" Text="{Binding AuthorPhotoPath}" Margin="0,0,4,0" />
          <Button Grid.Column="1" Content="Browse…" Click="OnBrowseAuthorPhotoClick" />
        </Grid>
        <TextBox Watermark="Author bio" Text="{Binding AuthorBio}"
                 AcceptsReturn="True" TextWrapping="Wrap" Height="90" />

        <TextBlock Text="Social Links" FontWeight="Bold" FontSize="16" Margin="0,12,0,0" />
        <ItemsControl ItemsSource="{Binding SocialLinks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SocialLinkEntry">
              <Grid ColumnDefinitions="*,2*,Auto" Margin="0,0,0,4">
                <TextBox Grid.Column="0" Watermark="Platform" Text="{Binding Platform}" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Watermark="URL" Text="{Binding Url}" Margin="0,0,4,0" />
                <Button Grid.Column="2" Content="✕" Click="OnRemoveSocialLinkClick" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="+ Add Social Link" Command="{Binding AddSocialLinkCommand}" />

      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="16">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Save &amp; Regenerate" Classes="accent" Click="OnSaveClick" />
    </StackPanel>
  </Grid>

</Window>
