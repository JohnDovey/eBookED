<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.UnsavedChangesDialog"
        Title="Unsaved Changes"
        Width="380" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20" Spacing="16">
    <TextBlock Text="This project has unsaved changes. Save before closing?" TextWrapping="Wrap" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Discard" Click="OnDiscardClick" />
      <Button Content="Save" Click="OnSaveClick" IsDefault="True" />
    </StackPanel>
  </StackPanel>

</Window>
