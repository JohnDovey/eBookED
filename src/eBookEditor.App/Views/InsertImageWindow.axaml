<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.InsertImageWindow"
        Title="Insert Image"
        Width="380" Height="480"
        MinWidth="340" MinHeight="420"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

    <CheckBox Grid.Row="0" x:Name="GalleryCheckBox" Content="Insert as Gallery (multiple images, up to 20)"
              IsCheckedChanged="OnGalleryCheckedChanged" Margin="0,0,0,12" />

    <Button Grid.Row="1" x:Name="PickImagesButton" Content="Choose Image…" Click="OnPickImagesButtonClick"
            HorizontalAlignment="Left" Margin="0,0,0,12" />

    <Border Grid.Row="2" x:Name="GallerySummaryBorder" BorderBrush="Gray" BorderThickness="1"
            Padding="8" Margin="0,0,0,12" MaxHeight="160" IsVisible="False">
      <ScrollViewer>
        <TextBlock x:Name="GallerySummaryText" TextWrapping="Wrap" />
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="3" x:Name="SingleImagePanel" Spacing="4" IsVisible="False">

      <TextBlock Text="Size" FontWeight="Bold" Margin="0,0,0,4" />
      <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Width (px)" FontSize="11" Opacity="0.7" />
          <NumericUpDown x:Name="WidthUpDown" Minimum="1" Increment="1"
                          FormatString="0" ValueChanged="OnWidthChanged" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="4">
          <TextBlock Text="Height (px)" FontSize="11" Opacity="0.7" />
          <NumericUpDown x:Name="HeightUpDown" Minimum="1" Increment="1"
                          FormatString="0" ValueChanged="OnHeightChanged" />
        </StackPanel>
      </Grid>
      <TextBlock x:Name="PageFitNoticeText" Opacity="0.7" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

      <TextBlock Text="Alignment" FontWeight="Bold" Margin="0,0,0,4" />
      <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
        <RadioButton x:Name="LeftRadio" Content="Left" GroupName="Alignment" IsCheckedChanged="OnAlignmentChanged" />
        <RadioButton x:Name="CenterRadio" Content="Center" GroupName="Alignment" IsChecked="True" IsCheckedChanged="OnAlignmentChanged" />
        <RadioButton x:Name="RightRadio" Content="Right" GroupName="Alignment" IsCheckedChanged="OnAlignmentChanged" />
      </StackPanel>

      <CheckBox x:Name="FlowCheckBox" Content="Flow text around image" Margin="0,0,0,4" />
      <TextBlock Opacity="0.7" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                 Text="Only available for left/right alignment — a centered image has no side for text to flow to." />

      <TextBlock Text="Caption" FontWeight="Bold" Margin="0,0,0,4" />
      <TextBox x:Name="CaptionTextBox" Watermark="Caption text" />

    </StackPanel>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button x:Name="InsertButton" Content="Insert" Classes="accent" Click="OnInsertClick" IsEnabled="False" />
    </StackPanel>

  </Grid>

</Window>
