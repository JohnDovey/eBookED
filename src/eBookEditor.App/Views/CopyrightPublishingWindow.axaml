<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:eBookEditor.App.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="640" d:DesignHeight="680"
        x:Class="eBookEditor.App.Views.CopyrightPublishingWindow"
        x:DataType="vm:MetadataViewModel"
        Title="Copyright &amp; Publishing"
        Width="640" Height="680"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" Padding="16">
      <StackPanel Spacing="10">

        <TextBox Watermark="Copyright holder" Text="{Binding CopyrightHolder}" />
        <TextBox Watermark="Copyright year" Text="{Binding CopyrightYear}" />
        <TextBox Watermark="Publisher name" Text="{Binding PublisherName}" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Watermark="Publisher logo path (relative to project)" Text="{Binding PublisherLogoPath}" Margin="0,0,4,0" />
          <Button Grid.Column="1" Content="Browse…" Click="OnBrowsePublisherLogoClick" />
        </Grid>
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Watermark="Cover image path (relative to project)" Text="{Binding CoverImagePath}" Margin="0,0,4,0" />
          <Button Grid.Column="1" Content="Browse…" Click="OnBrowseCoverImageClick" />
        </Grid>
        <TextBox Watermark="Publication date (yyyy-MM-dd)" Text="{Binding PublicationDate}" />
        <TextBox Watermark="ISBN-13" Text="{Binding Isbn13}" />
        <TextBox Watermark="ISBN-10" Text="{Binding Isbn10}" />
        <TextBox Watermark="Copyright disclaimer" Text="{Binding CopyrightDisclaimer}"
                 AcceptsReturn="True" TextWrapping="Wrap" Height="90" />

        <TextBlock Text="Where It's Sold" FontWeight="Bold" FontSize="16" Margin="0,12,0,0" />
        <ItemsControl ItemsSource="{Binding StoreLinks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:StoreLinkEntry">
              <Grid ColumnDefinitions="*,2*,Auto" Margin="0,0,0,4">
                <TextBox Grid.Column="0" Watermark="Store (e.g. KindleStore, AppleBooks)" Text="{Binding Store}" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Watermark="URL" Text="{Binding Url}" Margin="0,0,4,0" />
                <Button Grid.Column="2" Content="✕" Click="OnRemoveStoreLinkClick" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="+ Add Store Link" Command="{Binding AddStoreLinkCommand}" />

      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="16">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Save &amp; Regenerate" Classes="accent" Click="OnSaveClick" />
    </StackPanel>
  </Grid>

</Window>
