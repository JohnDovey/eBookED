<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.InsertFootnoteWindow"
        Title="Insert Footnote"
        Width="420" Height="220"
        MinWidth="320" MinHeight="180"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16" RowDefinitions="Auto,*,Auto">
    <TextBlock Grid.Row="0" Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap"
               Text="Type the footnote's text. A numbered reference is inserted at the cursor, and the note is added to (or started as) a Notes list at the end of this page." />

    <TextBox Grid.Row="1" x:Name="NoteText" AcceptsReturn="True" TextWrapping="Wrap"
             Watermark="Footnote text…" />

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Insert" Classes="accent" Click="OnInsertClick" />
    </StackPanel>
  </Grid>

</Window>
