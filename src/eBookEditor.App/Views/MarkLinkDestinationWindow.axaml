<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.MarkLinkDestinationWindow"
        Title="Mark Link Destination"
        Width="420" Height="200"
        MinWidth="320" MinHeight="180"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Grid.Row="0" Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap"
               Text="Give this destination a short label — it identifies the marked text in the &quot;Insert Internal Link&quot; picker elsewhere in the book." />

    <TextBox Grid.Row="1" x:Name="LabelText" Watermark="Label…" />

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Mark" Classes="accent" Click="OnMarkClick" />
    </StackPanel>
  </Grid>

</Window>
