<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="using:AvaloniaEditCore"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        xmlns:vm="using:eBookEditor.App.ViewModels"
        xmlns:models="using:eBookEditor.Core.Models"
        mc:Ignorable="d"
        d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="eBookEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="eBook Editor"
        Width="1100" Height="700">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    <KeyBinding Gesture="Cmd+S" Command="{Binding SaveProjectCommand}" />
  </Window.KeyBindings>

  <DockPanel>

    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
      <Menu Grid.Column="0">
        <MenuItem Header="_File">
          <MenuItem Header="New Project…" Click="OnNewProjectClick" />
          <MenuItem Header="Open Project…" Click="OnOpenProjectClick" />
          <MenuItem Header="Recent Projects" x:Name="RecentProjectsMenuItem" SubmenuOpened="OnRecentProjectsSubmenuOpened" />
          <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}" InputGesture="Ctrl+S" />
          <Separator />
          <MenuItem Header="Import DOCX…" Click="OnImportDocxClick" />
          <MenuItem Header="Import Chapters…" Click="OnImportChaptersClick" />
        </MenuItem>
        <MenuItem Header="_Project">
          <MenuItem Header="Regenerate Front Matter" Command="{Binding RegenerateFrontMatterCommand}" />
        </MenuItem>
        <MenuItem Header="_Meta Data">
          <MenuItem Header="Front Matter…" Click="OnEditFrontMatterClick" />
          <MenuItem Header="Style…" Click="OnEditStyleClick" />
          <MenuItem Header="Copyright &amp; Publishing…" Click="OnEditCopyrightPublishingClick" />
          <MenuItem Header="Genre Tags…" Click="OnEditGenreTagsClick" />
          <MenuItem Header="About the Author…" Click="OnEditAboutTheAuthorClick" />
          <MenuItem Header="PDF Settings…" Click="OnEditPdfSettingsClick" />
        </MenuItem>
        <MenuItem Header="_Export">
          <MenuItem Header="EPUB…" Command="{Binding ExportEpubCommand}" />
          <MenuItem Header="PDF…" Command="{Binding ExportPdfCommand}" />
          <MenuItem Header="Word (Whole Book)…" Command="{Binding ExportWordWholeBookCommand}" />
          <MenuItem Header="Markdown (Whole Book)…" Command="{Binding ExportMarkdownWholeBookCommand}" />
          <MenuItem Header="Markdown (This Chapter)…" Command="{Binding ExportMarkdownChapterCommand}"
                    IsEnabled="{Binding IsChapterSelected}" />
        </MenuItem>
      </Menu>
      <Menu Grid.Column="1">
        <MenuItem Header="About" Click="OnAboutClick" />
      </Menu>
    </Grid>

    <Border DockPanel.Dock="Bottom" Padding="8,4" BorderThickness="0,1,0,0" BorderBrush="Gray">
      <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
    </Border>

    <Grid ColumnDefinitions="260,*">

      <!-- Sidebar: chapters can be dragged to reorder; front/back matter are fixed.
           Also accepts external file drops (.md/.docx/.html) to import as new chapters. -->
      <Border Grid.Column="0" Background="{DynamicResource SystemAltHighColor}" BorderThickness="0,0,1,0" BorderBrush="Gray"
              DragDrop.AllowDrop="True" DragDrop.DragOver="OnSidebarDragOver" DragDrop.Drop="OnSidebarDrop">
        <DockPanel Margin="12">
          <TextBlock DockPanel.Dock="Top" Text="{Binding CurrentProject.Metadata.Title}"
                     FontWeight="Bold" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap" />

          <Button DockPanel.Dock="Top" Content="+ Add Chapter" Command="{Binding AddChapterCommand}"
                  HorizontalAlignment="Stretch" Margin="0,0,0,8" />

          <ListBox x:Name="SpineListBox" ItemsSource="{Binding SpineItems}"
                   SelectionChanged="OnSpineItemSelectionChanged">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="2,0" />
                <Setter Property="MinHeight" Value="0" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:SpineItem">
                <Border Background="Transparent" Padding="2,1"
                        PointerPressed="OnSpineItemPointerPressed"
                        PointerMoved="OnSpineItemPointerMoved"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="OnSpineItemDragOver"
                        DragDrop.Drop="OnSpineItemDrop">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Delete Chapter" Click="OnDeleteChapterClick" />
                      <MenuItem Header="Export Chapter as Word…" Click="OnExportChapterAsWordClick" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <TextBlock Text="{Binding DisplayTitle}" FontSize="11" TextWrapping="Wrap" />
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Editor pane -->
      <DockPanel Grid.Column="1" Margin="12">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <Button Content="{Binding Editor.ModeLabel, StringFormat='Mode: {0}'}"
                  Command="{Binding Editor.TogglePreviewCommand}" />
          <TextBlock Text="{Binding Editor.FilePath}" VerticalAlignment="Center" Opacity="0.6" />
        </StackPanel>

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*,Auto" IsVisible="{Binding IsChapterSelected}" Margin="0,0,0,8">
          <TextBox Grid.Column="0" Watermark="Chapter title" Text="{Binding ChapterTitleInput}" Margin="0,0,4,0" />
          <TextBox Grid.Column="1" Watermark="Chapter subheading" Text="{Binding ChapterSubtitleInput}" Margin="4,0" />
          <Button Grid.Column="2" Content="Apply" Command="{Binding SaveChapterHeaderCommand}" Margin="4,0,0,0" />
        </Grid>

        <Grid>
          <ae:TextEditor x:Name="EditorTextBox"
                         IsVisible="{Binding Editor.IsEditMode}"
                         FontFamily="Cascadia Code,Menlo,Consolas,monospace"
                         FontSize="14"
                         ShowLineNumbers="True"
                         WordWrap="True">
            <ae:TextEditor.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Insert Table…" Click="OnInsertTableClick" />
              </ContextMenu>
            </ae:TextEditor.ContextMenu>
          </ae:TextEditor>

          <md:MarkdownScrollViewer IsVisible="{Binding Editor.IsPreviewMode}"
                                    Markdown="{Binding Editor.PreviewSource}" />
        </Grid>
      </DockPanel>

    </Grid>

  </DockPanel>

</Window>
