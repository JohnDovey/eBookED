<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.WelcomeWindow"
        Title="eBook Editor"
        Width="440" Height="480"
        WindowStartupLocation="CenterScreen">

  <DockPanel Margin="24">

    <TextBlock DockPanel.Dock="Top" Text="eBook Editor" FontSize="24" FontWeight="Bold" />
    <TextBlock DockPanel.Dock="Top" Text="Create a new project or open an existing one." Opacity="0.7" Margin="0,4,0,16" />

    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
      <Button Content="New Project…" Classes="accent" Click="OnNewProjectClick" />
      <Button Content="Open Project…" Click="OnOpenProjectClick" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Top" Text="Recent Projects" FontWeight="SemiBold" Margin="0,0,0,8" />

    <ScrollViewer>
      <StackPanel x:Name="RecentProjectsPanel" Spacing="4" />
    </ScrollViewer>

  </DockPanel>

</Window>
