<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="eBookEditor.App.Views.MarkIndexEntryWindow"
        Title="Mark as Index Entry"
        Width="440" Height="240"
        MinWidth="360" MinHeight="220"
        WindowStartupLocation="CenterOwner">

  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Grid.Row="0" Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap"
               Text="Enter the term this text should appear under in the book's Index." />

    <TextBox Grid.Row="1" x:Name="TermText" Watermark="Term…" />

    <CheckBox Grid.Row="2" x:Name="MarkAllOccurrencesCheckBox" Margin="0,12,0,0"
              Content="Automatically mark all occurrences of this text in the current chapter" />

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="Mark" Classes="accent" Click="OnMarkClick" />
    </StackPanel>
  </Grid>

</Window>
