<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round vendors AvaloniaEdit's source
         instead of consuming it as a NuGet package — an internal restructuring with no new
         user-facing behavior, so a patch bump. -->
    <Version>1.2.1</Version>
  </PropertyGroup>
</Project>
