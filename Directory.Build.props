<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round adds chapter import (drag-and-drop
         and File menu picker) for .md/.docx/.html, orphan chapter-file scanning, filename-
         based chapter ordering/renumbering, an ordered-list sidebar, and working EPUB
         in-book TOC links — new features, so a minor bump. -->
    <Version>1.3.0</Version>
  </PropertyGroup>
</Project>
