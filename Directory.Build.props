<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round adds a chapter right-click context
         menu (Delete, Export as Word) and the Markdown-to-DOCX exporter it needs — new
         features, so a minor bump. -->
    <Version>1.4.0</Version>
  </PropertyGroup>
</Project>
