<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round adds a Recent Projects menu,
         restores last-session projects on launch, and switches the default theme to Light —
         new features, so a minor bump. -->
    <Version>1.2.0</Version>
  </PropertyGroup>
</Project>
