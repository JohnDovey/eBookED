<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round adds PDF export (QuestPDF), a
         page-size settings modal, a redesigned Imprint front-matter page with bottom-pinned
         copyright (PDF) / page-break-before chapters (EPUB), roman-numeral front matter
         page numbers, and a post-export result modal with word/page counts — all new
         features, so a minor bump. -->
    <Version>1.5.0</Version>
  </PropertyGroup>
</Project>
