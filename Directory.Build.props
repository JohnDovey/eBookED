<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round splits the single metadata editor
         into five focused windows under a top-level "Meta Data" menu, and fixes a bug where
         typing into a newly created chapter's editor didn't work — both are patch-level. -->
    <Version>1.1.3</Version>
  </PropertyGroup>
</Project>
