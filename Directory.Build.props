<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Bump the minor version for new features, patch for other code changes (see
         feedback_version_bump_policy memory). This round adds footnote support across
         EPUB/PDF/Word export (real Word FootnotesPart, QuestPDF endnotes-per-chapter,
         EPUB CSS polish) and table/image rendering in PDF and Word export — all new
         features, so a minor bump. -->
    <Version>1.6.0</Version>
  </PropertyGroup>
</Project>
